# Drug Discovery Tool — Local Development Environment
# Copy to ../.env.local and fill in your keys

# === LLM Provider Keys ===

# Anthropic (required for agentic mode — claude-sonnet-4-6 orchestrator)
ANTHROPIC_API_KEY=sk-ant-...

# NVIDIA NIM (free tier — required for Nemotron sub-agents)
# Get your free key at: https://build.nvidia.com/
NVIDIA_API_KEY=nvapi-...

# Optional other providers (classic mode only)
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=AIzaSy...
# COHERE_API_KEY=...

# === Backend Config ===
DISCOVERY_PROVIDER=anthropic
DISCOVERY_MODEL=claude-sonnet-4-6
ORCHESTRATOR_MODEL=claude-sonnet-4-6
SUB_AGENT_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
HAIKU_MODEL=claude-haiku-4-5-20251001
DB_PATH=./data/research.db

# === Frontend Config ===
REACT_APP_API_URL=http://localhost:8000
