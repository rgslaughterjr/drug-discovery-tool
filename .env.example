# Drug Discovery Pipeline: Environment Configuration
# Copy this file to .env and fill in your settings
# Alternatively, set environment variables directly in your shell

# ============================================================================
# PROVIDER SELECTION (required)
# ============================================================================
# Options: 'anthropic', 'openai', 'cohere', 'bedrock', 'ollama', 'together', or custom provider name
DISCOVERY_PROVIDER=anthropic

# ============================================================================
# API KEYS (required for most providers, except ollama)
# ============================================================================

# For Anthropic Direct API (orchestrator + Haiku synthesizer)
ANTHROPIC_API_KEY=sk-ant-

# For NVIDIA NIM — Nemotron sub-agents (free tier at build.nvidia.com)
NVIDIA_API_KEY=nvapi-

# For OpenAI (including Azure OpenAI)
OPENAI_API_KEY=sk-

# For Google Gemini
GOOGLE_API_KEY=AIzaSy-

# For Cohere
COHERE_API_KEY=

# For Together.ai
TOGETHER_API_KEY=

# For AWS Bedrock (uses AWS CLI credentials from ~/.aws/credentials, not API key)
# No key needed here; AWS credentials auto-loaded

# ============================================================================
# MODEL SELECTION (optional; provider defaults used if not set)
# ============================================================================
# Anthropic: claude-3-5-sonnet-20241022 (default)
# OpenAI: gpt-4o (default) or gpt-4, gpt-4-turbo, o1
# Google Gemini: gemini-2.0-flash (default) or gemini-1.5-pro, gemini-1.5-flash
# Cohere: command-r-plus (default) or command-r, command-light
# Ollama: llama2 (default) or mistral, neural-chat, zephyr, etc.
# Together: meta-llama/Llama-2-7b-chat-hf (default)
# Bedrock: claude-3-5-sonnet-20241022 (default)

DISCOVERY_MODEL=claude-3-5-sonnet-20241022

# ============================================================================
# CUSTOM API ENDPOINT (optional; for Ollama, Azure OpenAI, or custom APIs)
# ============================================================================
# Ollama default: http://localhost:11434/v1
# Azure OpenAI example: https://YOUR_RESOURCE.openai.azure.com/v1

DISCOVERY_BASE_URL=

# ============================================================================
# AWS BEDROCK CONFIGURATION (if using Bedrock provider)
# ============================================================================
# AWS region containing Bedrock (default: us-west-2)
AWS_REGION=us-west-2

# AWS credentials (auto-loaded from ~/.aws/credentials if not set here)
# Uncomment only if needed:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ============================================================================
# WEB UI CONFIGURATION (for React frontend)
# ============================================================================
# Backend API URL (frontend calls this URL for API requests)
# Development: http://localhost:8000
# Production: https://your-api-domain.com
REACT_APP_API_URL=http://localhost:8000

# ============================================================================
# LANGSMITH — Tracing & Observability (required for LangGraph agent debugging)
# Get your key at: https://smith.langchain.com
# ============================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__
LANGCHAIN_PROJECT=drug-discovery-tool
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================================================
# AGENTIC SYSTEM MODEL OVERRIDES (optional)
# ============================================================================
# Orchestrator brain (default: claude-sonnet-4-6)
ORCHESTRATOR_MODEL=claude-sonnet-4-6
# Nemotron sub-agents for heavy scientific reasoning (default: nvidia/llama-3.1-nemotron-70b-instruct)
SUB_AGENT_MODEL=nvidia/llama-3.1-nemotron-70b-instruct
# Follow-up chat synthesis (default: claude-haiku-4-5-20251001)
HAIKU_MODEL=claude-haiku-4-5-20251001
