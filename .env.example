# Drug Discovery Agent — Environment Configuration
# Copy to .env and fill in values before running locally.
# Never commit .env to version control.

# ============================================================================
# REQUIRED — LLM API KEYS
# ============================================================================

# Anthropic — orchestrator (claude-sonnet-4-6) + synthesizer (claude-haiku-4-5)
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-

# OpenRouter — Nemotron sub-agents (nvidia/nemotron-3-super-120b-a12b:free)
# Get free key at: https://openrouter.ai
OPENROUTER_API_KEY=sk-or-
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================================================
# LANGSMITH — Tracing & Observability
# Required to use LangSmith for agent debugging and trace inspection.
# Get key at: https://smith.langchain.com
# Set LANGCHAIN_TRACING_V2=false to disable tracing entirely.
# ============================================================================
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__
LANGCHAIN_PROJECT=drug-discovery-tool
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ============================================================================
# AGENTIC SYSTEM MODEL OVERRIDES (optional)
# Defaults shown — override only if testing a different model.
# ============================================================================
ORCHESTRATOR_MODEL=claude-sonnet-4-6
SUB_AGENT_MODEL=nvidia/nemotron-3-super-120b-a12b:free
HAIKU_MODEL=claude-haiku-4-5-20251001

# ============================================================================
# INFRASTRUCTURE (optional)
# ============================================================================

# SQLite database path for LangGraph checkpointer + research session storage
DB_PATH=./data/research.db

# React frontend → backend URL (change if backend is not on localhost)
REACT_APP_API_URL=http://localhost:8000
