# Drug Discovery Pipeline: Environment Configuration
# Copy this file to .env and fill in your settings
# Alternatively, set environment variables directly in your shell

# ============================================================================
# PROVIDER SELECTION (required)
# ============================================================================
# Options: 'anthropic', 'openai', 'cohere', 'bedrock', 'ollama', 'together', or custom provider name
DISCOVERY_PROVIDER=anthropic

# ============================================================================
# API KEYS (required for most providers, except ollama)
# ============================================================================

# For Anthropic Direct API
ANTHROPIC_API_KEY=sk-ant-

# For OpenAI (including Azure OpenAI)
OPENAI_API_KEY=sk-

# For Cohere
COHERE_API_KEY=

# For Together.ai
TOGETHER_API_KEY=

# For AWS Bedrock (uses AWS CLI credentials from ~/.aws/credentials, not API key)
# No key needed here; AWS credentials auto-loaded

# ============================================================================
# MODEL SELECTION (optional; provider defaults used if not set)
# ============================================================================
# Anthropic: claude-3-5-sonnet-20241022 (default)
# OpenAI: gpt-4-turbo (default) or gpt-4, gpt-3.5-turbo
# Cohere: command-r-plus (default) or command-r, command-light
# Ollama: llama2 (default) or mistral, neural-chat, zephyr, etc.
# Together: meta-llama/Llama-2-7b-chat-hf (default)
# Bedrock: claude-3-5-sonnet-20241022 (default)

DISCOVERY_MODEL=claude-3-5-sonnet-20241022

# ============================================================================
# CUSTOM API ENDPOINT (optional; for Ollama, Azure OpenAI, or custom APIs)
# ============================================================================
# Ollama default: http://localhost:11434/v1
# Azure OpenAI example: https://YOUR_RESOURCE.openai.azure.com/v1

DISCOVERY_BASE_URL=

# ============================================================================
# AWS BEDROCK CONFIGURATION (if using Bedrock provider)
# ============================================================================
# AWS region containing Bedrock (default: us-west-2)
AWS_REGION=us-west-2

# AWS credentials (auto-loaded from ~/.aws/credentials if not set here)
# Uncomment only if needed:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
